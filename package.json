{
  "name": "simple",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .development.env -- next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:push": "dotenv -e .development.env -- prisma db push --schema ./src/prisma/schema.prisma",
    "prisma:studio": "dotenv -e .development.env -- prisma studio --schema ./src/prisma/schema.prisma",
    "seed": "dotenv -e .development.env -- prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/prisma/seed.ts"
  },
  "dependencies": {
