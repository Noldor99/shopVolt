generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("PRISMA_DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  fullName String
  email    String  @unique
  phone    String?
  password String

  role UserRole @default(USER)

  provider   String?
  providerId String?

  basket            Basket?
  orders            Order[]
  favorites         Favorite[]
  verificationCodes VerificationCode[]

  verified  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum UserRole {
  USER
  MODER
  ADMIN
}

model Category {
  id   Int    @id @default(autoincrement())
  slug String @unique

  categoryAttributes CategoryAttribute[]
  translations       CategoryTranslation[]

  devices Device[]
  brands  Brand[]  @relation("CategoryToBrand")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryTranslation {
  id     Int    @id @default(autoincrement())
  name   String
  locale String

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId Int

  @@unique([categoryId, locale])
}

model Brand {
  id   Int    @id @default(autoincrement())
  name String @unique
  slug String @unique

  devices Device[]

  categories Category[] @relation("CategoryToBrand")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attribute {
  id Int @id @default(autoincrement())

  // Унікальний технічний ідентифікатор для розробника
  // Приклади: "color", "ram_size", "display_type", "cpu_model"
  code String @unique

  translations AttributeTranslation[]

  // Зв'язок із категоріями (які атрибути доступні в "Смартфонах", а які в "Ноутбуках")
  // Приклад: в категорії "Смартфони" є атрибут "nfc", а в "Процесорах" — ні.
  categoryAttributes CategoryAttribute[]

  // Приклад для "color": ["Red", "Blue", "Black"]
  // Приклад для "ram_size": ["8GB", "16GB", "32GB"]
  values AttributeValue[]
}

model AttributeTranslation {
  id Int @id @default(autoincrement())

  // Код мови. Приклади: "uk", "en", "pl"
  locale String

  name        String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeId Int

  @@unique([attributeId, locale])
}

model CategoryAttribute {
  id Int @id @default(autoincrement())

  categoryId  Int
  attributeId Int

  // Приклад: true для "Процесор" у категорії "Смартфони", false для "Наявність чохла"
  isRequired Boolean @default(false)

  // Чи є цей атрибут варіантом товару (впливає на вибір моделі)?
  isVariant Boolean @default(false)

  sortOrder Int @default(0)

  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  deviceInfos DeviceInfo[]

  deviceItemProperties DeviceItemProperty[]

  @@unique([categoryId, attributeId])
  @@index([categoryId, sortOrder])
  @@index([attributeId])
}

model Device {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  imageUrl  String
  imageUrls String[] @default([])

  priceUah     Int?
  oldPriceUah  Int?
  rating       Float?
  reviewsCount Int?
  inStock      Boolean @default(true)
  stockCount   Int?

  translations DeviceTranslation[]

  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int

  brand   Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  brandId Int?

  info      DeviceInfo[]
  items     DeviceItem[]
  favorites Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, brandId])
  @@index([priceUah])
  @@index([rating])
}

model DeviceTranslation {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  locale      String

  seoTitle       String?
  seoDescription String?

  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId Int

  @@unique([deviceId, locale])
}

model DeviceInfo {
  id Int @id @default(autoincrement())

  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId Int

  categoryAttributeId Int
  categoryAttribute   CategoryAttribute @relation(fields: [categoryAttributeId], references: [id], onDelete: Cascade)

  attributeValueId Int
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId])
  @@index([categoryAttributeId])
  @@index([attributeValueId])
}

model AttributeValue {
  id          Int       @id @default(autoincrement())
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  visualValue String?

  // Технічний код значення (незмінний, для логіки)
  // Приклади: "8gb", "16gb", "black", "amoled"
  code String

  translations AttributeValueTranslation[]

  deviceInfos DeviceInfo[]

  deviceItemProperties DeviceItemProperty[]

  @@unique([attributeId, code])
  @@index([attributeId])
}

model AttributeValueTranslation {
  id     Int    @id @default(autoincrement())
  value  String
  locale String

  attributeValueId Int
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([attributeValueId, locale])
}

model DeviceItem {
  id          Int     @id @default(autoincrement())
  sku         String  @unique
  priceUah    Int
  oldPriceUah Int?
  stockCount  Int     @default(0)
  inStock     Boolean @default(true)
  mainImage   String

  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId Int

  properties    DeviceItemProperty[]
  basketDevices BasketDevice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deviceId])
}

model DeviceItemProperty {
  id Int @id @default(autoincrement())

  deviceItem   DeviceItem @relation(fields: [deviceItemId], references: [id], onDelete: Cascade)
  deviceItemId Int

  // Яке саме правило атрибута ми використовуємо
  // Приклад: Атрибут "Колір", який у категорії "Смартфони" позначений як isVariant = true
  categoryAttribute   CategoryAttribute @relation(fields: [categoryAttributeId], references: [id], onDelete: Cascade)
  categoryAttributeId Int

  // Конкретне обране значення
  // Приклад: "Синій" (ID значення з моделі AttributeValue)
  attributeValueId Int
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@index([deviceItemId])
  @@index([categoryAttributeId])
  @@index([attributeValueId])
}

model Basket {
  id Int @id @default(autoincrement())

  user   User? @relation(fields: [userId], references: [id])
  userId Int?  @unique

  tokenId String? @unique

  devices     BasketDevice[]
  totalAmount Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BasketDevice {
  id Int @id @default(autoincrement())

  basket   Basket @relation(fields: [basketId], references: [id], onDelete: Cascade)
  basketId Int

  deviceItem   DeviceItem @relation(fields: [deviceItemId], references: [id], onDelete: Restrict)
  deviceItemId Int

  quantity Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([basketId, deviceItemId])
  @@index([deviceItemId])
}

model Favorite {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, deviceId])
}

model Order {
  id Int @id @default(autoincrement())

  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  items Json?

  status      OrderStatus @default(PENDING)
  totalAmount Int
  paymentId   String?

  fullName String
  address  String
  email    String
  phone    String
  comment  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  SUCCEEDED
  CANCELLED
}

model VerificationCode {
  id Int @id @default(autoincrement())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  code   String

  expiresAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, code])
}
